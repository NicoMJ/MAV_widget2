# THIS FILE IS A TEMPLATE — scripts/setup_network.sh generates the installed version
# with the actual adapter MAC detected at install time.
[connection]
id=GCS-Radio
uuid=2f3b5aeb-bc73-3a2c-8cd8-8a79935a0f8e
type=ethernet
interface-name=eth0
autoconnect=true
autoconnect-priority=100

[ethernet]

[ipv4]
method=manual
address1=192.168.53.1/24
never-default=true

[ipv6]
method=disabled
