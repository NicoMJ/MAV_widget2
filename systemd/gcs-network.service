[Unit]
Description=Ensure GCS eth0=192.168.53.1 and eth1=USB debug
After=NetworkManager.service network-pre.target
Before=network-online.target drone-hotspot.service
Wants=NetworkManager.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/ensure-network.sh

[Install]
WantedBy=multi-user.target
